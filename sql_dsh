-- ------------------------------------------------------------
-- 3. appsec_summary
-- Одна строка с общими KPI — самый быстрый источник для карточек
-- FineBI просто читает готовые цифры
-- ------------------------------------------------------------
DROP VIEW IF EXISTS custom_ts_secure_development.appsec_summary;

CREATE VIEW custom_ts_secure_development.appsec_summary AS
SELECT
    -- Открытые дефекты
    COUNT(CASE WHEN is_active_int = 1 AND is_security_debt = FALSE THEN 1 END)
        AS total_open,
    COUNT(CASE WHEN is_active_int = 1 AND severity = 'CRITICAL'
               AND is_security_debt = FALSE THEN 1 END)
        AS open_critical,
    COUNT(CASE WHEN is_active_int = 1 AND severity = 'HIGH'
               AND is_security_debt = FALSE THEN 1 END)
        AS open_high,
    -- Красная зона
    COUNT(CASE WHEN is_red_zone_int = 1 THEN 1 END)
        AS red_zone_total,
    -- Блокируют релиз
    COUNT(CASE WHEN is_release_blocking_int = 1 THEN 1 END)
        AS release_blockers,
    -- Risk Accepted просроченных
    COUNT(CASE WHEN is_ra_overdue_int = 1 THEN 1 END)
        AS ra_overdue,
    -- Fixed за 30 дней
    COUNT(CASE WHEN is_fixed_30d_int = 1 THEN 1 END)
        AS fixed_30d,
    -- Security Debt
    COUNT(CASE WHEN is_security_debt AND is_active_int = 1 THEN 1 END)
        AS security_debt_total,
    COUNT(CASE WHEN is_security_debt AND is_active_int = 1
               AND severity = 'CRITICAL' THEN 1 END)
        AS security_debt_critical,
    COUNT(CASE WHEN is_security_debt AND is_active_int = 1
               AND severity = 'HIGH' THEN 1 END)
        AS security_debt_high,
    -- Дней до дедлайна Security Debt
    EXTRACT(DAY FROM TIMESTAMP '2027-01-01 00:00:00' - NOW())::INTEGER
        AS days_to_deadline,
    -- Текущее время снапшота
    NOW()::DATE AS snapshot_date
FROM custom_ts_secure_development.issues_current;


-- ------------------------------------------------------------
-- 4. security_debt_forecast
-- Прогноз погашения Security Debt
-- Нужен для графика с прогнозной линией в FineBI
-- ------------------------------------------------------------
DROP VIEW IF EXISTS custom_ts_secure_development.security_debt_forecast;

CREATE VIEW custom_ts_secure_development.security_debt_forecast AS
WITH
-- Текущий остаток
current_debt AS (
    SELECT
        COUNT(CASE WHEN is_active_int = 1 THEN 1 END) AS remaining,
        COUNT(CASE WHEN is_fixed_30d_int = 1 THEN 1 END) AS fixed_30d
    FROM custom_ts_secure_development.issues_current
    WHERE is_security_debt = TRUE
),
-- Темп закрытия в день
velocity AS (
    SELECT
        CASE WHEN fixed_30d > 0
            THEN fixed_30d / 30.0
            ELSE 0
        END AS daily_velocity
    FROM current_debt
)
SELECT
    NOW()::DATE                                         AS calc_date,
    c.remaining                                         AS current_remaining,
    c.fixed_30d                                         AS fixed_last_30d,
    v.daily_velocity                                    AS daily_velocity,
    -- Дней до полного погашения при текущем темпе
    CASE WHEN v.daily_velocity > 0
        THEN (c.remaining / v.daily_velocity)::INTEGER
        ELSE NULL
    END                                                 AS days_to_zero,
    -- Остаток на 01.01.2027 при текущем темпе
    GREATEST(0,
        c.remaining - (
            v.daily_velocity *
            EXTRACT(DAY FROM TIMESTAMP '2027-01-01' - NOW())
        )
    )::INTEGER                                          AS forecast_remaining_at_deadline,
    -- Успеваем или нет
    CASE WHEN v.daily_velocity > 0
         AND (c.remaining / v.daily_velocity) <=
             EXTRACT(DAY FROM TIMESTAMP '2027-01-01' - NOW())
        THEN 'ON TRACK'
        ELSE 'AT RISK'
    END                                                 AS forecast_status,
    EXTRACT(DAY FROM TIMESTAMP '2027-01-01 00:00:00' - NOW())::INTEGER
        AS days_to_deadline
FROM current_debt c, velocity v;


-- ------------------------------------------------------------
-- 5. products_full
-- Расширенная сводка по продуктам для сравнительной таблицы
-- Одна строка = один продукт, все KPI готовы
-- ------------------------------------------------------------
DROP VIEW IF EXISTS custom_ts_secure_development.products_full;

CREATE VIEW custom_ts_secure_development.products_full AS
WITH
current_stats AS (
    SELECT
        product_id,
        product_name,
        COUNT(DISTINCT repository)                                          AS repos_count,
        -- Текущие открытые (не Security Debt)
        SUM(CASE WHEN is_active_int = 1 AND severity = 'CRITICAL'
                 AND is_security_debt = FALSE THEN 1 ELSE 0 END)            AS open_critical,
        SUM(CASE WHEN is_active_int = 1 AND severity = 'HIGH'
                 AND is_security_debt = FALSE THEN 1 ELSE 0 END)            AS open_high,
        -- Красная зона и блокировки
        SUM(is_red_zone_int)                                                AS red_zone_count,
        SUM(is_release_blocking_int)                                        AS release_blockers,
        SUM(is_ra_overdue_int)                                              AS overdue_ra,
        -- Security Debt
        SUM(CASE WHEN is_security_debt AND is_active_int = 1
                 THEN 1 ELSE 0 END)                                         AS security_debt_total,
        SUM(CASE WHEN is_security_debt AND is_active_int = 1
                 AND severity = 'CRITICAL' THEN 1 ELSE 0 END)               AS security_debt_critical,
        SUM(CASE WHEN is_security_debt AND is_active_int = 1
                 AND severity = 'HIGH' THEN 1 ELSE 0 END)                   AS security_debt_high,
        -- Fixed и Reopened
        SUM(is_fixed_30d_int)                                               AS fixed_30d,
        SUM(CASE WHEN status = 'reopened'
                 AND severity IN ('CRITICAL','HIGH') THEN 1 ELSE 0 END)     AS reopened_ch,
        -- Exclusions
        SUM(CASE WHEN status = 'exclusion' THEN 1 ELSE 0 END)              AS exclusions
    FROM custom_ts_secure_development.issues_current
    GROUP BY product_id, product_name
),
mttr AS (
    SELECT product_id, mttr_days
    FROM custom_ts_secure_development.mttr_by_product
    WHERE severity = 'CRITICAL'   -- берём MTTR по Critical
)
SELECT
    s.*,
    m.mttr_days,
    -- Флаг красной зоны для условного форматирования в FineBI
    CASE WHEN s.red_zone_count > 0 OR s.release_blockers > 0
        THEN 1 ELSE 0 END AS has_red_zone
FROM current_stats s
LEFT JOIN mttr m ON s.product_id = m.product_id
ORDER BY s.open_critical DESC, s.open_high DESC;


