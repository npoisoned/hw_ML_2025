-- ------------------------------------------------------------
-- 1. issues_current
-- Одна строка = один актуальный дефект из последнего снапшота
-- Это главный источник для KPI карточек в FineBI
-- ------------------------------------------------------------
DROP VIEW IF EXISTS custom_ts_secure_development.issues_current;

CREATE VIEW custom_ts_secure_development.issues_current AS
WITH last_snapshot AS (
    -- Берём только последний снапшот
    SELECT MAX(ts) AS max_ts
    FROM custom_ts_secure_development.issues_snapshot
),
ranked AS (
    SELECT
        i.*,
        -- Флаги для FineBI (SUM вместо COUNT DISTINCT)
        1                                               AS issue_cnt,
        CASE WHEN i.is_active THEN 1 ELSE 0 END        AS is_active_int,
        -- Красная зона
        CASE WHEN (
            (i.status = 'risk_accepted' AND i.severity = 'CRITICAL'
                AND i.ra_deadline IS NOT NULL AND i.ra_deadline < NOW())
            OR
            (i.status = 'risk_accepted' AND i.severity = 'HIGH'
                AND i.ra_deadline IS NOT NULL AND i.ra_deadline < NOW())
            OR
            (i.status = 'confirmed' AND i.severity = 'CRITICAL')
            OR
            (i.status = 'confirmed' AND i.severity = 'HIGH'
                AND i.updated_at < NOW() - INTERVAL '60 days')
            OR
            (i.is_security_debt AND i.is_active
                AND NOW() > TIMESTAMP '2027-01-01 00:00:00')
            OR
            (i.status = 'reopened' AND i.severity IN ('CRITICAL','HIGH'))
        ) THEN 1 ELSE 0 END                             AS is_red_zone_int,
        -- Блокирует релиз
        CASE WHEN (
            (i.status = 'confirmed' AND i.severity = 'CRITICAL')
            OR
            (i.status = 'confirmed' AND i.severity = 'HIGH'
                AND i.updated_at < NOW() - INTERVAL '60 days')
            OR
            (i.is_security_debt AND i.is_active
                AND NOW() > TIMESTAMP '2027-01-01 00:00:00')
        ) THEN 1 ELSE 0 END                             AS is_release_blocking_int,
        -- Risk Accepted просрочен
        CASE WHEN (
            i.status = 'risk_accepted'
            AND i.ra_deadline IS NOT NULL
            AND i.ra_deadline < NOW()
        ) THEN 1 ELSE 0 END                             AS is_ra_overdue_int,
        -- Fixed за последние 30 дней
        CASE WHEN (
            i.status = 'fixed'
            AND i.updated_at >= NOW() - INTERVAL '30 days'
        ) THEN 1 ELSE 0 END                             AS is_fixed_30d_int,
        -- Дней открыт
        EXTRACT(DAY FROM NOW() - i.created_at)::INTEGER AS days_open,
        -- Дней просрочен (для RA)
        CASE WHEN i.ra_deadline IS NOT NULL AND i.ra_deadline < NOW()
            THEN EXTRACT(DAY FROM NOW() - i.ra_deadline)::INTEGER
            ELSE 0
        END                                             AS days_overdue,
        -- Читаемый статус для FineBI
        CASE i.status
            WHEN 'new_issue'      THEN 'New'
            WHEN 'recurrent'      THEN 'New'
            WHEN 'confirmed'      THEN 'Confirmed'
            WHEN 'risk_accepted'  THEN 'Risk Accepted'
            WHEN 'reopened'       THEN 'Reopened'
            WHEN 'security-debt'  THEN 'Security Debt'
            WHEN 'fixed'          THEN 'Fixed'
            WHEN 'false_positive' THEN 'False Positive'
            WHEN 'exclusion'      THEN 'Exclusion'
            ELSE i.status
        END                                             AS status_display,
        -- Приоритет для сортировки в детальной таблице
        CASE
            WHEN i.status = 'confirmed' AND i.severity = 'CRITICAL' THEN 1
            WHEN i.status = 'reopened'  AND i.severity = 'CRITICAL' THEN 2
            WHEN i.status = 'risk_accepted' AND i.severity = 'CRITICAL'
                AND i.ra_deadline < NOW()               THEN 3
            WHEN i.severity = 'CRITICAL'                THEN 4
            WHEN i.status = 'confirmed' AND i.severity = 'HIGH'     THEN 5
            WHEN i.status = 'reopened'  AND i.severity = 'HIGH'     THEN 6
            WHEN i.status = 'risk_accepted' AND i.severity = 'HIGH'
                AND i.ra_deadline < NOW()               THEN 7
            WHEN i.severity = 'HIGH'                    THEN 8
            ELSE 99
        END                                             AS priority_order
    FROM custom_ts_secure_development.issues_snapshot i
    CROSS JOIN last_snapshot l
    WHERE i.ts = l.max_ts
)
SELECT * FROM ranked;


